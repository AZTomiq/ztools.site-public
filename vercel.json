{
  "cleanUrls": true,
  "trailingSlash": true,
  "redirects": [
    {
      "source": "/compound-interest/:path*",
      "destination": "https://laikep.ztools.site/:path*",
      "permanent": true
    },
    {
      "source": "/tax/:path*",
      "destination": "https://tncn.ztools.site/:path*",
      "permanent": true
    },
    {
      "source": "/json-toolkit/:path*",
      "destination": "https://json.ztools.site/:path*",
      "permanent": true
    },
    {
      "source": "/web-playground/:path*",
      "destination": "https://playground.ztools.site/:path*",
      "permanent": true
    },
    {
      "source": "/blog/:path*",
      "destination": "https://blog.ph4n4n.xyz/:path*",
      "permanent": true
    },
    {
      "source": "/roadmap/:path*",
      "destination": "https://roadmap.ph4n4n.xyz/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/assets/:path*",
      "destination": "/assets/:path*"
    },
    {
      "source": "/en/:path*",
      "has": [
        {
          "type": "host",
          "value": "playground.ztools.site"
        }
      ],
      "destination": "/en/web-playground/:path*"
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "playground.ztools.site"
        },
        {
          "type": "header",
          "key": "x-vercel-ip-country",
          "value": "VN",
          "invert": true
        }
      ],
      "destination": "/en/web-playground/:path"
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "playground.ztools.site"
        }
      ],
      "destination": "/web-playground/:path"
    },
    {
      "source": "/en/:path*",
      "has": [
        {
          "type": "host",
          "value": "tncn.ztools.site"
        }
      ],
      "destination": "/en/tax/:path*"
