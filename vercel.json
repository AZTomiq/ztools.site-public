{
  "cleanUrls": true,
  "trailingSlash": true,
  "redirects": [
    {
      "source": "/web-playground/:path*",
      "has": [
        {
          "type": "host",
          "value": "ztools.site"
        }
      ],
      "destination": "https://playground.ztools.site/:path*",
      "permanent": true
    },
    {
      "source": "/tax/:path*",
      "has": [
        {
          "type": "host",
          "value": "ztools.site"
        }
      ],
      "destination": "https://tncn.ztools.site/:path*",
      "permanent": true
    },
    {
      "source": "/json-toolkit/:path*",
      "has": [
        {
          "type": "host",
          "value": "ztools.site"
        }
      ],
      "destination": "https://json.ztools.site/:path*",
      "permanent": true
    },
    {
      "source": "/compound-interest/:path*",
      "has": [
        {
          "type": "host",
          "value": "ztools.site"
        }
      ],
      "destination": "https://laikep.ztools.site/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/assets/:path*",
      "destination": "/assets/:path*"
    },
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "playground.ztools.site"
        }
      ],
      "destination": "/web-playground/index.html"
    },
    {
      "source": "/en/",
      "has": [
        {
          "type": "host",
          "value": "playground.ztools.site"
        }
      ],
      "destination": "/en/web-playground/index.html"
    },
    {
      "source": "/:path+",
      "has": [
        {
          "type": "host",
          "value": "playground.ztools.site"
        }
      ],
      "destination": "/web-playground/:path"
    },
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "tncn.ztools.site"
        }
      ],
      "destination": "/tax/index.html"
    },
    {
      "source": "/en/",
      "has": [
        {
          "type": "host",
          "value": "tncn.ztools.site"
        }
      ],
      "destination": "/en/tax/index.html"
    },
    {
      "source": "/:path+",
      "has": [
        {
          "type": "host",
          "value": "tncn.ztools.site"
        }
      ],
      "destination": "/tax/:path"
    },
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "laikep.ztools.site"
        }
      ],
      "destination": "/compound-interest/index.html"
    },
    {
      "source": "/en/",
      "has": [
        {
          "type": "host",
          "value": "laikep.ztools.site"
        }
      ],
      "destination": "/en/compound-interest/index.html"
    },
    {
      "source": "/:path+",
      "has": [
        {
          "type": "host",
          "value": "laikep.ztools.site"
        }
      ],
      "destination": "/compound-interest/:path"
    },
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "json.ztools.site"
        }
      ],
      "destination": "/json-toolkit/index.html"
    },
    {
      "source": "/en/",
      "has": [
        {
          "type": "host",
          "value": "json.ztools.site"
        }
      ],
      "destination": "/en/json-toolkit/index.html"
    },
    {
      "source": "/:path+",
      "has": [
        {
          "type": "host",
          "value": "json.ztools.site"
        }
      ],
      "destination": "/json-toolkit/:path"
    },
    {
      "source": "/:path((?!en/|assets/|api/|sw\\.js|manifest\\.json|sitemap\\.xml|robots\\.txt).*)",
      "has": [
        {
          "type": "host",
          "value": "ztools.site"
        },
        {
          "type": "query",
          "key": "lang",
          "value": "en"
        }
      ],
      "destination": "/en/:path"
    },
    {
      "source": "/:path((?!en/|assets/|api/|sw\\.js|manifest\\.json|sitemap\\.xml|robots\\.txt).*)",
      "has": [
        {
          "type": "host",
          "value": "ztools.site"
        },
        {
          "type": "header",
          "key": "x-vercel-ip-country",
          "value": "VN",
          "invert": true
        }
      ],
      "destination": "/en/:path"
    }
  ]
}